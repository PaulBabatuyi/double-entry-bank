{
  "buildCommand": "npm run build || true",
  "outputDirectory": ".",
  "trailingSlash": false,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/swagger",
      "destination": "https://double-entry-bank-go.onrender.com/swagger/index.html"
    },
    {
      "source": "/swagger/",
      "destination": "https://double-entry-bank-go.onrender.com/swagger/index.html"
    },
    {
      "source": "/swagger-ui.css",
      "destination": "https://double-entry-bank-go.onrender.com/swagger/swagger-ui.css"
    },
    {
      "source": "/swagger-ui-bundle.js",
      "destination": "https://double-entry-bank-go.onrender.com/swagger/swagger-ui-bundle.js"
    },
    {
      "source": "/swagger-ui-standalone-preset.js",
      "destination": "https://double-entry-bank-go.onrender.com/swagger/swagger-ui-standalone-preset.js"
    },
    {
      "source": "/swagger/favicon-16x16.png",
      "destination": "https://double-entry-bank-go.onrender.com/swagger/favicon-16x16.png"
    },
    {
      "source": "/swagger/favicon-32x32.png",
      "destination": "https://double-entry-bank-go.onrender.com/swagger/favicon-32x32.png"
    },
    {
      "source": "/swagger/:path*",
      "destination": "https://double-entry-bank-go.onrender.com/swagger/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_API_BASE_URL": "https://double-entry-bank-go.onrender.com"
  }
}
