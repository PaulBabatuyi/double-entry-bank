{
  "buildCommand": "npm run build || true",
  "outputDirectory": ".",
  "trailingSlash": false,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/swagger",
      "destination": "https://double-entry-bank-go.onrender.com/swagger"
    },
    {
      "source": "/swagger/",
      "destination": "https://double-entry-bank-go.onrender.com/swagger/"
    },
    {
      "source": "/swagger/:path*",
      "destination": "https://double-entry-bank-go.onrender.com/swagger/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_API_BASE_URL": "https://double-entry-bank-go.onrender.com"
  }
}
